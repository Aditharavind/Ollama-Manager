        card = QFrame(); card.setObjectName("card"); card.setFixedHeight(165)
        lay = QVBoxLayout(card); lay.setContentsMargins(14,12,14,12); lay.setSpacing(6)

        top = QHBoxLayout()
        n = QLabel(m["name"]); n.setFont(QFont("Courier New",13,QFont.Bold)); n.setStyleSheet("color:#f1f5f9;")
        installed = m["name"] in self.installed_models
        st = QLabel("● INSTALLED" if installed else f"{m['size_gb']} GB")
        st.setStyleSheet("color:#4ade80; font-size:11px;" if installed else "color:#64748b; font-size:11px;")
        top.addWidget(n); top.addStretch(); top.addWidget(st); lay.addLayout(top)

        desc = QLabel(m["desc"]); desc.setStyleSheet("color:#64748b; font-size:11px;"); desc.setWordWrap(True)
        lay.addWidget(desc)

        tr = QHBoxLayout(); tr.setSpacing(4)
        for tag in m["tags"][:3]: t2 = QLabel(tag); t2.setObjectName("mono_tag"); tr.addWidget(t2)
        tr.addStretch(); lay.addLayout(tr)

        ram_ok = m["ram_gb"] <= ram_gb*0.85
        if installed:
            btn = QPushButton("● INSTALLED"); btn.setObjectName("btn_success"); btn.setEnabled(False)
        elif ram_ok:
            btn = QPushButton("⬇  PULL  MODEL"); btn.setObjectName("btn_primary")
