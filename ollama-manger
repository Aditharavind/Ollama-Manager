    def _sublabel(self, txt):
        l = QLabel(txt); l.setObjectName("subheading"); return l

    def _populate_model_cards(self):
        for i in reversed(range(self.model_cards_layout.count())):
            wi = self.model_cards_layout.itemAt(i).widget()
            if wi: wi.deleteLater()

        ram_gb   = psutil.virtual_memory().total/(1024**3)
        q        = self.filter_box.text().lower() if hasattr(self,"filter_box") else ""
        show_all = self.show_all_cb.isChecked() if hasattr(self,"show_all_cb") else False
        col = row = 0

        for m in MODEL_CATALOG:
            if q and q not in m["name"].lower() and q not in m["desc"].lower(): continue
            if not show_all and m["ram_gb"] > ram_gb*0.85: continue
            self.model_cards_layout.addWidget(self._make_model_card(m, ram_gb), row, col)
            col += 1
            if col == 2: col = 0; row += 1

        if self.model_cards_layout.count() == 0:
            lbl = QLabel("No models match — try 'Show all' or clear filter.")
            lbl.setAlignment(Qt.AlignCenter); lbl.setStyleSheet("color:#475569; padding:30px;")
            self.model_cards_layout.addWidget(lbl,0,0)

