        port = self.port_spin.value() if hasattr(self,"port_spin") else 8600
        self.lan_url_lbl.setText(f"LAN  →  http://{LAN_IP}:{port}")
        self.docs_box.setPlainText(
            f"# Anyone on your network can reach this server\n"
            f"BASE  http://{LAN_IP}:{port}\n\n"
            f"GET   /api/models        → list installed models\n"
            f"GET   /health            → server health\n"
            f"POST  /api/chat          → generate (blocking or stream)\n"
            f"POST  /api/generate      → alias for /api/chat\n\n"
            f"─── Blocking ──────────────────────────────────────────────\n"
            f'curl -X POST http://{LAN_IP}:{port}/api/chat \\\n'
            f'  -H "Content-Type: application/json" \\\n'
            f'  -d \'{{"model":"mistral","prompt":"Hello!"}}\'\n\n'
            f"─── Streaming (SSE) ───────────────────────────────────────\n"
            f'curl -X POST http://{LAN_IP}:{port}/api/chat \\\n'
            f'  -H "Content-Type: application/json" \\\n'
            f'  -d \'{{"model":"mistral","prompt":"Hello!","stream":true}}\'\n'
            f"  # Each chunk: data: {{\"response\":\"...\",\"done\":false}}\n"
            f"  # Final line: data: [DONE]"
        )

    # ── Logic: Ollama ─────────────────────────────────────────────────────────
    def check_ollama(self):
        self.ollama_status_lbl.setText("Checking..."); self.ollama_status_lbl.setStyleSheet("color:#fbbf24;")
        self.status_badge.setText("● CHECKING..."); self.status_badge.setStyleSheet("color:#fbbf24; font-family:'Courier New'; font-size:12px;")
        try:
            r = subprocess.run(["ollama","--version"], capture_output=True, text=True, timeout=5)
            ver = r.stdout.strip() or "installed"
            self.ollama_status_lbl.setText("● INSTALLED"); self.ollama_status_lbl.setStyleSheet("color:#4ade80;")
            self.status_badge.setText("● OLLAMA  READY"); self.status_badge.setStyleSheet("color:#4ade80; font-family:'Courier New'; font-size:12px;")
            self.version_lbl.setText(f"Version: {ver}")
            self.btn_install.setEnabled(False); self.btn_install.setText("✓  INSTALLED")
            self._log_setup(f"[OK] {ver}"); self.refresh_installed_models()
        except (FileNotFoundError, subprocess.TimeoutExpired):
            self.ollama_status_lbl.setText("● NOT FOUND"); self.ollama_status_lbl.setStyleSheet("color:#f87171;")
            self.status_badge.setText("● NOT FOUND"); self.status_badge.setStyleSheet("color:#f87171; font-family:'Courier New'; font-size:12px;")
            self.version_lbl.setText("Version: —"); self.btn_install.setEnabled(True)
            self._log_setup("[WARN] Ollama not found. Click INSTALL OLLAMA.")

    def install_ollama(self):
        self.btn_install.setEnabled(False); self.install_progress.setVisible(True)
        self.install_thread = InstallOllamaThread()
        self.install_thread.log.connect(self._log_setup)
        self.install_thread.done.connect(self._install_done); self.install_thread.start()

    def _install_done(self, ok):
        self.install_progress.setVisible(False)
        if ok: self.check_ollama()
        else: self.btn_install.setEnabled(True)

    def _log_setup(self, msg):
        self.setup_log.append(f'<span style="color:#475569;">[{self._ts()}]</span> <span style="color:#94a3b8;">{msg}</span>')
        self.setup_log.moveCursor(QTextCursor.End)

    # ── Logic: Models ─────────────────────────────────────────────────────────
    def refresh_installed_models(self):
        try:
            r = subprocess.run(["ollama","list"], capture_output=True, text=True, timeout=5)
            lines = r.stdout.strip().split("\n")[1:]
            self.installed_models = [l.split()[0] for l in lines if l.strip()]
        except: self.installed_models = []

        for cb in (self.chat_model_combo, self.api_model_combo):
            cb.clear()
            for m in self.installed_models: cb.addItem(m)
        self._populate_model_cards()

    def pull_model(self, name):
        name = name.strip()
        if not name: return
        self.pull_log.append(f'<span style="color:#38bdf8;">[PULL]</span> Queuing: <b>{name}</b>')
        self.pull_progress.setVisible(True); self.pull_progress.setValue(0)
        t = PullModelThread(name)
        t.log.connect(lambda msg: self.pull_log.append(f'<span style="color:#475569;">{msg}</span>'))
        t.progress.connect(self.pull_progress.setValue)
        t.done.connect(self._pull_done); t.start()
        self.pull_threads[name] = t

    def pull_custom_model(self):
        name = self.custom_model_input.text().strip()
        if not name:
            self.pull_log.append('<span style="color:#f87171;">[ERR] Enter a model name first.</span>'); return
        self.custom_model_input.clear()
        self.tabs.setCurrentIndex(1)
        self.pull_model(name)

    def _pull_done(self, ok, name):
        if ok:
            self.pull_log.append(f'<span style="color:#4ade80;">[OK] {name} is ready!</span>')
            self.refresh_installed_models()
        else:
            self.pull_log.append(
                f'<span style="color:#f87171;">[ERR] Failed to pull <b>{name}</b>. '
                f'Verify the name at ollama.com/library</span>')
        self.pull_progress.setVisible(False)

    # ── Logic: Chat ───────────────────────────────────────────────────────────
    def send_chat(self):
        model = self.chat_model_combo.currentText(); prompt = self.chat_input.text().strip()
        if not model or not prompt: return
        self.chat_input.clear(); self.btn_send.setEnabled(False)
        label = "Streaming" if self.stream_cb.isChecked() else "Generating"
        self.chat_status.setText(f"{label}  ·  {model}…")

        self.chat_display.append(
            f'<br><span style="color:#38bdf8; font-weight:bold;">YOU</span><br>'
            f'<span style="color:#e2e8f0;">{prompt}</span><br><br>'
            f'<span style="color:#4ade80; font-weight:bold;">ASSISTANT</span><br>'
        )
        self.chat_history.append({"role":"user","content":prompt})
        self._current_response = ""

        self.chat_thread = StreamChatThread(model, list(self.chat_history))
        self.chat_thread.token.connect(self._stream_token)
        self.chat_thread.done.connect(self._chat_done)
        self.chat_thread.error.connect(self._chat_error)
        self.chat_thread.start()

    def _stream_token(self, tok):
        self._current_response += tok
        cursor = self.chat_display.textCursor(); cursor.movePosition(QTextCursor.End)
        cursor.insertText(tok); self.chat_display.setTextCursor(cursor); self.chat_display.ensureCursorVisible()

    def _chat_done(self):
        self.btn_send.setEnabled(True); self.chat_status.setText("Done.")
        self.chat_display.append("")
        self.chat_history.append({"role":"assistant","content":self._current_response})

    def _chat_error(self, err):
        self.chat_display.append(
            f'<br><span style="color:#f87171;">[ERR] {err}</span>'
            f'<br><span style="color:#475569;">Is Ollama running?  Run:  ollama serve</span>'
        )
        self.btn_send.setEnabled(True); self.chat_status.setText("Error.")

    def clear_chat(self):
        self.chat_display.clear(); self.chat_history = []; self.chat_status.setText("Chat cleared.")

    # ── Logic: API ────────────────────────────────────────────────────────────
    def start_api_server(self):
        port = self.port_spin.value()
        try:
            self.api_server = HTTPServer(("0.0.0.0", port), OllamaAPIHandler)
            threading.Thread(target=self.api_server.serve_forever, daemon=True).start()
            self.api_status_lbl.setText(f"● RUNNING  :  {port}")
            self.api_status_lbl.setStyleSheet("color:#4ade80; font-family:'Courier New'; font-size:12px;")
            self.btn_start_api.setEnabled(False); self.btn_stop_api.setEnabled(True); self.port_spin.setEnabled(False)
            self._api_log(f'<span style="color:#4ade80;">[START] Listening  0.0.0.0:{port}  ·  LAN  http://{LAN_IP}:{port}</span>')
        except Exception as e:
            self._api_log(f'<span style="color:#f87171;">[ERR] {e}</span>')

    def stop_api_server(self):
        if self.api_server:
            threading.Thread(target=self.api_server.shutdown, daemon=True).start(); self.api_server = None
        self.api_status_lbl.setText("● STOPPED"); self.api_status_lbl.setStyleSheet("color:#f87171; font-family:'Courier New'; font-size:12px;")
        self.btn_start_api.setEnabled(True); self.btn_stop_api.setEnabled(False); self.port_spin.setEnabled(True)
        self._api_log('<span style="color:#fbbf24;">[STOP] Server stopped.</span>')

    def _api_log(self, html):
        self.api_log_box.append(f'<span style="color:#475569;">[{self._ts()}]</span> {html}')
        self.api_log_box.moveCursor(QTextCursor.End)

    def closeEvent(self, event):
        self.stop_api_server(); event.accept()


